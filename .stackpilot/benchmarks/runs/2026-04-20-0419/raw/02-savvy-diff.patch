@@ -1,4 +1,7 @@
 import type { Request, Response, NextFunction } from 'express';
+import { RATE_LIMITS } from '../config/limits';
+import { redis } from '../lib/redis';
+import { logger } from '../lib/logger';
 
 export interface AuthedRequest extends Request {
   userId?: string;
@@ -46,3 +49,38 @@ export function requireAuth(req: AuthedRequest, res: Response, next: NextFunctio
   req.sessionId = token;
   next();
 }
+
+export async function rateLimit(
+  req: AuthedRequest,
+  res: Response,
+  next: NextFunction,
+): Promise<void> {
+  const userId = req.userId;
+  if (!userId) {
+    res.status(401).json({ error: 'missing bearer token' });
+    return;
+  }
+
+  const windowSeconds = Math.ceil(RATE_LIMITS.windowMs / 1000);
+  const key = `ratelimit:user:${userId}`;
+
+  const count = await redis.incr(key);
+  if (count === 1) {
+    await redis.expire(key, windowSeconds);
+  }
+
+  if (count > RATE_LIMITS.perUserPerMinute) {
+    const pttl = await redis.pttl(key);
+    const retryAfter = pttl > 0 ? Math.ceil(pttl / 1000) : windowSeconds;
+    logger.warn('rate limit exceeded', {
+      userId,
+      count,
+      limit: RATE_LIMITS.perUserPerMinute,
+      retryAfter,
+    });
+    res.status(429).json({ error: 'rate limit exceeded', retryAfter });
+    return;
+  }
+
+  next();
+}
