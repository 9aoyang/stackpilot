 }
+
+export async function rateLimit(req: AuthedRequest, res: Response, next: NextFunction): Promise<void> {
+  const userId = req.userId;
+  if (!userId) {
+    next();
+    return;
+  }
+
+  const key = `ratelimit:user:${userId}`;
+
+  try {
+    const count = await redis.incr(key);
+    if (count === 1) {
+      await redis.expire(key, Math.ceil(RATE_LIMITS.windowMs / 1000));
+    }
+
+    if (count > RATE_LIMITS.perUserPerMinute) {
+      const pttl = await redis.pttl(key);
+      const retryAfter = Math.max(1, Math.ceil(pttl / 1000));
+      logger.warn('rate limit exceeded', { userId, count });
+      res.setHeader('Retry-After', String(retryAfter));
+      res.status(429).json({ error: 'rate limit exceeded', retryAfter });
+      return;
+    }
+  } catch (err) {
+    logger.error('rate limit redis error', { userId, err });
+  }
+
+  next();
+}
