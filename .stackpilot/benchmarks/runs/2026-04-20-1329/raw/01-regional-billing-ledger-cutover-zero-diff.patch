@@ -0,0 +1,21 @@
+import assert from "node:assert/strict";
+import test from "node:test";
+import { exists, read } from "../helpers/read-file.mjs";
+
+test("billing writes are routed through regional ledger write modes", () => {
+  assert.equal(exists("src/ledger/events.ts"), true, "regional ledger writer must exist");
+  const source = [
+    read("src/billing/invoiceService.ts"),
+    read("src/billing/refundService.ts"),
+    read("src/ledger/events.ts"),
+  ].join("\n");
+
+  assert.match(source, /getLedgerWriteMode/);
+  assert.match(source, /writeLedgerEvent/);
+  assert.match(source, /mode === "legacy"/);
+  assert.match(source, /mode === "dual"/);
+  assert.match(source, /mode === "ledger"/);
+  assert.match(source, /invoice\.paid/);
+  assert.match(source, /refund\.created/);
+  assert.doesNotMatch(source, /writeLegacyLedger/);
+});
