+++ b/bench-sandbox/src/jobs/reconcileStripe.ts
@@ -1,9 +1,22 @@
 import { listInvoicesForExport } from "../billing/invoiceService";
+import { db } from "../db/client";
+import { listInvoicesFromLedger } from "../ledger/currentLedgerView";
 
 export async function reconcileStripe() {
   const invoices = await listInvoicesForExport();
+  const ledgerInvoices = listInvoicesFromLedger();
+  const legacyTotalCents = [...db.invoices.values()].reduce((sum, invoice) => sum + invoice.amountCents, 0);
+  const ledgerTotalCents = ledgerInvoices.reduce((sum, invoice) => sum + invoice.amountCents, 0);
+
   return {
     invoiceCount: invoices.length,
     totalCents: invoices.reduce((sum, invoice) => sum + invoice.amountCents, 0),
+    parity: {
+      legacyInvoiceCount: db.invoices.size,
+      ledgerInvoiceCount: ledgerInvoices.length,
+      legacyTotalCents,
+      ledgerTotalCents,
+      matched: db.invoices.size === ledgerInvoices.length && legacyTotalCents === ledgerTotalCents,
+    },
   };
 }
