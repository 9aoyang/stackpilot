--- a/bench-sandbox/src/billing/invoiceService.ts
+++ b/bench-sandbox/src/billing/invoiceService.ts
@@ -1,13 +1,33 @@
 import { db } from "../db/client";
 import type { Invoice } from "../db/types";
+import { getLedgerReadMode, getLedgerWriteMode } from "../lib/featureFlags";
 import { assertCents } from "../lib/money";
+import { listRegionalLedgerEvents, recordInvoicePaidLedgerEvent } from "../ledger/events";
 
 export async function recordInvoicePaid(invoice: Invoice) {
   assertCents(invoice.amountCents);
+  const writeMode = getLedgerWriteMode();
+  if (writeMode === "dual" || writeMode === "ledger") {
+    await recordInvoicePaidLedgerEvent({ invoice, source: "billing_service" });
+  }
   db.invoices.set(invoice.id, { ...invoice, status: "paid" });
   return db.invoices.get(invoice.id)!;
 }
 
 export async function listInvoicesForExport() {
+  if (getLedgerReadMode() === "ledger") {
+    return listRegionalLedgerEvents()
+      .filter((event) => event.type === "invoice.paid")
+      .map((event) => ({
+        id: event.invoiceId,
+        accountId: event.accountId,
+        subscriptionId: event.subscriptionId ?? "",
+        amountCents: event.amountCents,
+        currency: event.currency,
+        region: event.region,
+        status: "paid" as const,
+        createdAt: event.createdAt,
+      }));
+  }
   return [...db.invoices.values()].sort((a, b) => a.createdAt.localeCompare(b.createdAt));
 }
