@@ -1,7 +1,27 @@
-/**
- * Placeholder job. The real implementation must backfill historical invoice
- * rows into v2 regional ledger events without locking the full invoice table.
- */
-export async function backfillLedger() {
-  throw new Error("not implemented");
+import { db } from "../db/client";
+import { recordInvoicePaidLedgerEvent } from "../ledger/events";
+
+export type BackfillLedgerOptions = {
+  afterId?: string;
+  limit?: number;
+};
+
+export async function backfillLedger({ afterId, limit = 100 }: BackfillLedgerOptions = {}) {
+  const orderedInvoices = [...db.invoices.values()].sort((a, b) => a.id.localeCompare(b.id));
+  const nextIndex = afterId
+    ? orderedInvoices.findIndex((invoice) => invoice.id > afterId)
+    : 0;
+  const startIndex = nextIndex === -1 ? orderedInvoices.length : nextIndex;
+  const batch = orderedInvoices.slice(startIndex, startIndex + limit);
+
+  for (const invoice of batch) {
+    await recordInvoicePaidLedgerEvent({ invoice, source: "billing_service" });
+  }
+
+  const lastSeen = batch.at(-1)?.id ?? afterId ?? null;
+  return {
+    processed: batch.length,
+    cursor: lastSeen,
+    hasMore: lastSeen ? orderedInvoices.some((invoice) => invoice.id > lastSeen) : false,
+  };
 }
diff --git a/bench-sandbox/src/ledger/events.ts b/bench-sandbox/src/ledger/events.ts
new file mode 100644
index 0000000..4b5d514
--- /dev/null
+++ b/bench-sandbox/src/ledger/events.ts
@@ -0,0 +1,80 @@
+import { db } from "../db/client";
+import type { Invoice, LedgerEvent, Refund } from "../db/types";
+import { markProcessedOnce } from "../lib/idempotency";
+import { assertCents } from "../lib/money";
+
+type InvoicePaidInput = {
+  invoice: Invoice;
+  source: "stripe_webhook" | "billing_service";
+};
+
+type RefundCreatedInput = {
+  refund: Refund;
+  invoice?: Invoice;
+  source: "refund_api" | "billing_service";
+};
+
+function sanitizePayload(payload: Record<string, string | number | boolean | null>) {
+  return payload;
+}
+
+async function appendLedgerEvent(event: LedgerEvent): Promise<LedgerEvent | null> {
+  const firstSeen = await markProcessedOnce(`ledger:${event.idempotencyKey}`);
+  if (!firstSeen) return null;
+  db.ledgerEvents.set(event.id, event);
+  return event;
+}
+
+export async function recordInvoicePaidLedgerEvent({
+  invoice,
+  source,
+}: InvoicePaidInput): Promise<LedgerEvent | null> {
+  assertCents(invoice.amountCents);
+  return appendLedgerEvent({
+    id: `ledger_${invoice.region}_${invoice.id}_paid`,
+    type: "invoice.paid",
+    schemaVersion: 2,
+    idempotencyKey: `invoice.paid:${invoice.region}:${invoice.id}`,
+    region: invoice.region,
+    accountId: invoice.accountId,
+    invoiceId: invoice.id,
+    subscriptionId: invoice.subscriptionId,
+    amountCents: invoice.amountCents,
+    currency: invoice.currency,
+    createdAt: invoice.createdAt,
+    safePayload: sanitizePayload({
+      source,
+      status: "paid",
+    }),
+  });
+}
+
+export async function recordRefundCreatedLedgerEvent({
+  refund,
+  invoice,
+  source,
+}: RefundCreatedInput): Promise<LedgerEvent | null> {
+  assertCents(refund.amountCents);
+  return appendLedgerEvent({
+    id: `ledger_${refund.region}_${refund.id}_created`,
+    type: "refund.created",
+    schemaVersion: 2,
+    idempotencyKey: `refund.created:${refund.region}:${refund.id}`,
+    region: refund.region,
+    accountId: invoice?.accountId ?? "unknown",
+    invoiceId: refund.invoiceId,
+    subscriptionId: invoice?.subscriptionId,
+    refundId: refund.id,
+    amountCents: refund.amountCents,
+    currency: refund.currency,
+    createdAt: refund.createdAt,
+    safePayload: sanitizePayload({
+      source,
+      invoiceStatus: invoice?.status ?? null,
+    }),
+  });
+}
+
+export function listRegionalLedgerEvents(): LedgerEvent[] {
+  return [...db.ledgerEvents.values()].sort((a, b) => a.createdAt.localeCompare(b.createdAt));
+}
diff --git a/bench-sandbox/tests/contract/cutover-contract.test.mjs b/bench-sandbox/tests/contract/cutover-contract.test.mjs
