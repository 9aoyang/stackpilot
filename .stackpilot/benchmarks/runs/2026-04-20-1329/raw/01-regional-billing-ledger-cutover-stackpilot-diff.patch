+++ b/bench-sandbox/tests/contract/cutover-contract.test.mjs
@@ -14,3 +14,24 @@ test("cutover is dual-write capable and rollback-safe", () => {
   assert.match(source, /BILLING_LEDGER_READ_MODE|getLedgerReadMode|legacy/);
   assert.match(source, /shadow|reconcile|parity|compare/i);
 });
+
+test("billing write paths use regional ledger events without removing legacy compatibility writes", () => {
+  const source = [
+    read("src/billing/invoiceService.ts"),
+    read("src/billing/refundService.ts"),
+    read("src/ledger/events.ts"),
+  ].join("\n");
+  assert.match(source, /recordInvoicePaidLedgerEvent/);
+  assert.match(source, /recordRefundCreatedLedgerEvent/);
+  assert.match(source, /getLedgerWriteMode\(\)/);
+  assert.match(source, /writeMode === "dual" \|\| writeMode === "ledger"/);
+  assert.match(source, /db\.invoices\.set/);
+  assert.match(source, /db\.refunds\.set/);
+});
+
+test("invoice export can read the regional ledger projection during cutover", () => {
+  const source = read("src/billing/invoiceService.ts");
+  assert.match(source, /getLedgerReadMode\(\) === "ledger"/);
+  assert.match(source, /listRegionalLedgerEvents\(\)/);
+  assert.match(source, /event\.type === "invoice\.paid"/);
+});
