+
+export async function listInvoicesFromLedger(): Promise<Invoice[]> {
+  const invoices = new Map<string, Invoice>();
+
+  for (const event of [...db.ledgerEvents.values()].sort((a, b) =>
+    a.createdAt.localeCompare(b.createdAt),
+  )) {
+    if (event.type === "invoice.paid") {
+      invoices.set(event.invoiceId, {
+        id: event.invoiceId,
+        accountId: event.accountId,
+        subscriptionId: event.subscriptionId ?? "",
+        amountCents: event.amountCents,
+        currency: event.currency,
+        region: event.region,
+        status: "paid",
+        createdAt: event.createdAt,
+      });
+    }
+
+    if (event.type === "refund.created") {
+      const invoice = invoices.get(event.invoiceId) ?? db.invoices.get(event.invoiceId);
+      if (invoice) invoices.set(event.invoiceId, { ...invoice, status: "refunded" });
+    }
+  }
+
+  return [...invoices.values()].sort((a, b) => a.createdAt.localeCompare(b.createdAt));
+}
diff --git a/bench-sandbox/src/ledger/events.ts b/bench-sandbox/src/ledger/events.ts
new file mode 100644
index 0000000..7196115
--- /dev/null
+++ b/bench-sandbox/src/ledger/events.ts
@@ -0,0 +1,78 @@
+import { db } from "../db/client";
+import type { Invoice, LedgerEvent, Refund } from "../db/types";
+import { assertCents } from "../lib/money";
+
+type LedgerEventInput =
+  | { type: "invoice.paid"; invoice: Invoice }
+  | { type: "refund.created"; refund: Refund; invoice?: Invoice };
+
+function sanitize(input: LedgerEventInput): LedgerEvent["safePayload"] {
+  if (input.type === "invoice.paid") {
+    return {
+      invoiceId: input.invoice.id,
+      accountId: input.invoice.accountId,
+      subscriptionId: input.invoice.subscriptionId,
+      status: "paid",
+    };
+  }
+
+  return {
+    refundId: input.refund.id,
+    invoiceId: input.refund.invoiceId,
+    accountId: input.invoice?.accountId ?? null,
+    status: "refunded",
+  };
+}
+
+function toEvent(input: LedgerEventInput): LedgerEvent {
+  if (input.type === "invoice.paid") {
+    const { invoice } = input;
+    assertCents(invoice.amountCents);
+    return {
+      id: `ledger:${invoice.region}:invoice:${invoice.id}`,
+      schemaVersion: 2,
+      idempotencyKey: `invoice.paid:${invoice.id}`,
+      type: "invoice.paid",
+      region: invoice.region,
+      accountId: invoice.accountId,
+      invoiceId: invoice.id,
+      subscriptionId: invoice.subscriptionId,
+      amountCents: invoice.amountCents,
+      currency: invoice.currency,
+      createdAt: invoice.createdAt,
+      safePayload: sanitize(input),
+    };
+  }
+
+  const { refund, invoice } = input;
+  const invoiceEvent = [...db.ledgerEvents.values()].find(
+    (event) => event.type === "invoice.paid" && event.invoiceId === refund.invoiceId,
+  );
+  assertCents(refund.amountCents);
+  return {
+    id: `ledger:${refund.region}:refund:${refund.id}`,
+    schemaVersion: 2,
+    idempotencyKey: `refund.created:${refund.id}`,
+    type: "refund.created",
+    region: refund.region,
+    accountId: invoice?.accountId ?? invoiceEvent?.accountId ?? "unknown",
+    invoiceId: refund.invoiceId,
+    subscriptionId: invoice?.subscriptionId ?? invoiceEvent?.subscriptionId,
+    refundId: refund.id,
+    amountCents: refund.amountCents,
+    currency: refund.currency,
+    createdAt: refund.createdAt,
+    safePayload: sanitize(input),
+  };
+}
+
+export async function writeLedgerEvent(input: LedgerEventInput): Promise<LedgerEvent> {
+  const event = toEvent(input);
+  const existing = [...db.ledgerEvents.values()].find(
+    (candidate) => candidate.idempotencyKey === event.idempotencyKey,
+  );
+  if (existing) return existing;
+
+  db.ledgerEvents.set(event.id, event);
+  return event;
+}
