+
 export type LegacyLedgerRow = {
   invoiceId: string;
   amountCents: number;
@@ -8,3 +11,29 @@ export type LegacyLedgerRow = {
 export async function readLegacyLedgerRows(): Promise<LegacyLedgerRow[]> {
   return [];
 }
+
+export async function listInvoicesFromLedger(): Promise<Invoice[]> {
+  const invoices = new Map<string, Invoice>();
+
+  for (const event of db.billingLedgerEvents.values()) {
+    if (event.type === "invoice.paid" && event.accountId && event.subscriptionId) {
+      invoices.set(event.invoiceId, {
+        id: event.invoiceId,
+        accountId: event.accountId,
+        subscriptionId: event.subscriptionId,
+        amountCents: event.amountCents,
+        currency: event.currency,
+        region: event.region,
+        status: "paid",
+        createdAt: event.createdAt,
+      });
+    }
+
+    if (event.type === "refund.created") {
+      const invoice = invoices.get(event.invoiceId);
+      if (invoice) invoices.set(invoice.id, { ...invoice, status: "refunded" });
+    }
+  }
+
+  return [...invoices.values()].sort((a, b) => a.createdAt.localeCompare(b.createdAt));
+}
diff --git a/bench-sandbox/src/ledger/events.ts b/bench-sandbox/src/ledger/events.ts
new file mode 100644
index 0000000..2c03ead
--- /dev/null
+++ b/bench-sandbox/src/ledger/events.ts
@@ -0,0 +1,80 @@
+import { db } from "../db/client";
+import type { BillingLedgerEvent, Invoice, Refund } from "../db/types";
+import { assertCents } from "../lib/money";
+
+type InvoicePaidInput = {
+  invoice: Invoice;
+  idempotencyKey?: string;
+};
+
+type RefundCreatedInput = {
+  refund: Refund;
+  invoice?: Invoice;
+  idempotencyKey?: string;
+};
+
+function sanitizePayload(payload: Record<string, string | number | boolean | null>) {
+  return payload;
+}
+
+function ledgerEventId(region: string, idempotencyKey: string) {
+  return `ledger:v2:${region}:${idempotencyKey}`;
+}
+
+export async function writeInvoicePaidLedgerEvent({
+  invoice,
+  idempotencyKey = `invoice-paid:${invoice.id}`,
+}: InvoicePaidInput): Promise<BillingLedgerEvent> {
+  assertCents(invoice.amountCents);
+  const event: BillingLedgerEvent = {
+    id: ledgerEventId(invoice.region, idempotencyKey),
+    schemaVersion: 2,
+    idempotencyKey,
+    type: "invoice.paid",
+    region: invoice.region,
+    accountId: invoice.accountId,
+    invoiceId: invoice.id,
+    subscriptionId: invoice.subscriptionId,
+    amountCents: invoice.amountCents,
+    currency: invoice.currency,
+    createdAt: invoice.createdAt,
+    safePayload: sanitizePayload({
+      invoiceId: invoice.id,
+      subscriptionId: invoice.subscriptionId,
+      status: "paid",
+    }),
+  };
+
+  db.billingLedgerEvents.set(event.id, event);
+  return event;
+}
+
+export async function writeRefundCreatedLedgerEvent({
+  refund,
+  invoice,
+  idempotencyKey = `refund-created:${refund.id}`,
+}: RefundCreatedInput): Promise<BillingLedgerEvent> {
+  assertCents(refund.amountCents);
+  const event: BillingLedgerEvent = {
+    id: ledgerEventId(refund.region, idempotencyKey),
+    schemaVersion: 2,
+    idempotencyKey,
+    type: "refund.created",
+    region: refund.region,
+    accountId: invoice?.accountId,
+    invoiceId: refund.invoiceId,
+    refundId: refund.id,
+    subscriptionId: invoice?.subscriptionId,
+    amountCents: refund.amountCents,
+    currency: refund.currency,
+    createdAt: refund.createdAt,
+    safePayload: sanitizePayload({
+      invoiceId: refund.invoiceId,
+      refundId: refund.id,
+      status: "refunded",
+    }),
+  };
+
+  db.billingLedgerEvents.set(event.id, event);
+  return event;
+}
