#!/usr/bin/env bash
# stackpilot pre-commit hook
# Rejects commits that have inconsistent versions, outdated docs, or failing tests.
# Install: git config core.hooksPath .githooks

set -euo pipefail

FAIL=0
warn() { echo "pre-commit: FAIL — $1" >&2; FAIL=1; }

# 1. Version consistency: VERSION == SKILL.md == plugin.json
SKILL_VER=$(grep -m1 'version:' claude-config/skills/stackpilot/SKILL.md | sed 's/.*"\(.*\)"/\1/')
PLUGIN_VER=$(jq -r '.version' .claude-plugin/plugin.json)
VERSION_FILE=$(tr -d '[:space:]' < VERSION)
if [ "$SKILL_VER" != "$PLUGIN_VER" ]; then
  warn "Version mismatch: SKILL.md=$SKILL_VER, plugin.json=$PLUGIN_VER"
fi
if [ "$SKILL_VER" != "$VERSION_FILE" ]; then
  warn "Version mismatch: SKILL.md=$SKILL_VER, VERSION=$VERSION_FILE"
fi

# 2. CHANGELOG must mention the current version
if ! grep -q "\[$SKILL_VER\]" CHANGELOG.md; then
  warn "CHANGELOG.md has no entry for version $SKILL_VER"
fi

# 3. If agent/skill files changed (beyond version-only bumps), architecture docs must also be updated
STAGED=$(git diff --cached --name-only)
SKILL_CHANGED=$(echo "$STAGED" | grep -cE '^claude-config/(agents|skills)/' || true)
DOCS_CHANGED=$(echo "$STAGED" | grep -cE '^(docs/architecture|README\.md|CONTRIBUTING\.md)' || true)
if [ "$SKILL_CHANGED" -gt 0 ] && [ "$DOCS_CHANGED" -eq 0 ]; then
  # Allow version-only changes (release commits) without doc updates
  SKILL_DIFF=$(git diff --cached -- claude-config/ | grep '^[+-]' | grep -v '^[+-][+-][+-]' | grep -cvE '^\+.*version:|^-.*version:' || true)
  if [ "$SKILL_DIFF" -gt 0 ]; then
    warn "Agent/skill files changed but docs not updated (check: architecture.md, README.md, CONTRIBUTING.md)"
  fi
fi

# 4. Tests pass
if ! bash tests/test-init.sh > /dev/null 2>&1; then
  warn "tests/test-init.sh failed"
fi

if [ "$FAIL" -gt 0 ]; then
  echo "" >&2
  echo "pre-commit: Commit rejected. Fix the issues above and retry." >&2
  exit 1
fi
