#!/usr/bin/env bash
# pre-merge-commit — stackpilot pre-merge quality gate
# Runs before a squash-merge commit is finalised on main.
#
# Checks enforced:
#   1. Ensure sp-qa report is present in the PR description.
#   2. Confirm Stage 4 Consistency Audit section is non-empty in the report.
#   3. Reject merge if any [CRITICAL] finding is unresolved.

set -euo pipefail

REPORT_FILE="${1:-}"

if [[ -z "$REPORT_FILE" ]]; then
  echo "pre-merge-commit: no report file supplied" >&2
  exit 1
fi

if ! grep -q "Stage 4 Consistency Audit" "$REPORT_FILE"; then
  echo "pre-merge-commit: sp-qa report missing Stage 4 Consistency Audit section" >&2
  exit 1
fi

if grep -q "\[CRITICAL\]" "$REPORT_FILE"; then
  echo "pre-merge-commit: unresolved CRITICAL findings block merge" >&2
  exit 1
fi

echo "pre-merge-commit: all checks passed"
