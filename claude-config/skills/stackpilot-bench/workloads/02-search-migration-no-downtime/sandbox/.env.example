# Primary datastore for documents. Used by both writes and the current ILIKE
# search path. Required in every environment.
DATABASE_URL=postgres://search:search@localhost:5432/search

# Port the HTTP server binds to. Behind the internal ALB in prod.
PORT=4100

# Log level for src/lib/logger.ts. One of: debug|info|warn|error.
LOG_LEVEL=info
